<Window x:Class="WpfApp.Windows.ChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp.Windows"
        mc:Ignorable="d"
        Title="ChoiceWindow" MinHeight="200" MinWidth="270" Height="250" Width="310" MaxHeight="320" MaxWidth="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition MaxHeight="100"/>
        </Grid.RowDefinitions>
        <Grid Margin="10" Grid.Row="0">
            <ComboBox x:Name="Choice_CB" HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="50"/>
        </Grid>
        <Grid Margin="10" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="Accept" Grid.Column="0" Padding="5" Content="Выбрать" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Accept_Click"/>
            <Button x:Name="Declaim" Grid.Column="1" Padding="5" Content="Отмена" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Declaim_Click"/>
        </Grid>
    </Grid>
</Window>
