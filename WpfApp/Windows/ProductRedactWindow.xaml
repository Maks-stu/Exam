<Window x:Class="WpfApp.Windows.ProductRedactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp.Windows"
        mc:Ignorable="d"
        Title="ProductRedactWindow" MinHeight="250" MinWidth="800" Height="350" Width="830" MaxHeight="410" MaxWidth="1150">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Margin="10" Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Артикул" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox x:Name="Article_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Наименование:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox x:Name="Name_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="0" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Ед. Измерения:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox x:Name="Unit_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="0" Grid.Column="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Цена:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox x:Name="Price_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Категория:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <ComboBox x:Name="Category_CB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Производитель:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <ComboBox x:Name="Manufacturer_CB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="1" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Поставщик:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <ComboBox x:Name="Supplier_CB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="1" Grid.Column="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Скидка:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox x:Name="DiscountPercent_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="2" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Количество товаров на складе:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox x:Name="StockQuantity_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="2" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Описание:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox TextWrapping="Wrap" Margin="5" x:Name="Description_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>
        <Grid Margin="10" Grid.Row="2" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*" MinWidth="100"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock TextWrapping="Wrap" Text="Фотография:"/>
                <Button Content="Введите путь" x:Name="PhotoPath_B" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Click="PhotoPath_B_Click"/>
            </StackPanel>
            <Image x:Name="Image" Source="/images/picture.png" Grid.Column="1" Width="100" Height="100"/>
        </Grid>
        <Grid Margin="10" Grid.Row="2" Grid.Column="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="Accept" Grid.Column="0" Padding="5" Content="Принять" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Accept_Click"/>
            <Button x:Name="Declaim" Grid.Column="1" Padding="5" Content="Отмена" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Declaim_Click"/>
        </Grid>
    </Grid>
</Window>
