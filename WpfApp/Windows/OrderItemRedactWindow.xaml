<Window x:Class="WpfApp.Windows.OrderItemRedactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp.Windows"
        mc:Ignorable="d"
        Title="OrderItemRedactWindow" MinHeight="260" MinWidth="310" Height="300" Width="370" MaxHeight="360" MaxWidth="480">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition MaxHeight="100"/>
        </Grid.RowDefinitions>
        <Grid Margin="10" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="ID заказа" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <ComboBox x:Name="Order_CB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Наименование продукта:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <ComboBox x:Name="ProductName_CB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Text="Кол-во:" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <TextBox x:Name="Quantity_TB" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="10" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="Accept" Grid.Column="0" Padding="5" Content="Принять" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Accept_Click"/>
            <Button x:Name="Declaim" Grid.Column="1" Padding="5" Content="Отмена" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Declaim_Click"/>
        </Grid>
    </Grid>
</Window>
